{
  "name": "oja",
  "private": true,
  "workspaces": [
    "engine"
  ],
  "scripts": {
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "down:infra": "docker compose -f infra/docker-compose.yml down",
    "dev:engine": "npm --workspace engine run start:dev",
    "build:engine": "npm --workspace engine run build",
    "typecheck:engine": "npm --workspace engine run typecheck",
    "dev:gateway": "go run ./gateway",
    "dev:worker": "go run ./worker"
  }
}